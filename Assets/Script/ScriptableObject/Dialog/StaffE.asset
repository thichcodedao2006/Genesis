  m_Script: {fileID: 11500000, guid: 6963998228035b74b8adfcaa69bf3c46, type: 3}
  m_Name: StaffE
  m_EditorClassIdentifier: 
  NPCid: 5
  NPCname: "\u0440\u0443\u0441\u0441\u043A\u0438\u0439 \u043C\u0443\u0436\u0447\u0438\u043D\u0430"
  NPCAva: {fileID: -340626375, guid: 8a98d52d20f4f9049a3e00ba9c355930, type: 3}
  ListDialog:
  - DialogID: 0
    SentenceList:
    - "\u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435,
      \u043D\u043E\u0432\u044B\u0435 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B!"
    - "Ch\xE0o b\u1EA1n, t\xF4i l\xE0 ti\u1EBFn s\u0129 b\xEAn Nga, kh\xF4ng ng\u1ED1
      m\u1EDBi v\u1EC1 tr\u01B0\u1EDDng, ti\u1EBFng vi\u1EC7t c\xF2n d\u1EE1."
    - "Server tr\u01B0\u1EDDng n\u1ED5 r\u1ED3i!. Theo x\xE1c \u0111\u1ECBnh s\u01A1
      b\u1ED9 th\xEC n\xF3 b\u1ECB thi\u1EBFu data \u0111\u01B0\u1EE3c l\u01B0u trong
      th\u1EBB nh\u1EDB hay thi\u1EBFt b\u1ECB t\u01B0\u01A1ng t\u1EF1 th\u1EBF"
    - "\u042F \u043D\u0435 \u0437\u043D\u0430\u044E, sao t\xF4i bi\u1EBFt \u0111\u01B0\u1EDDng
      ki\u1EBFm \u0111\xE2y. C\u1EADu h\xE3y t\xECm th\u1EED \u1EDF c\xE1c t\xF2a
      nha."
    autoProgress: 00000100
  - DialogID: 1
    SentenceList:
    - "T\xECm ch\xECa kh\xF3a tr\u01B0\u1EDBc nh\xE9!"
    - "Pha n\xE0y conan g\u1ECDi b\u1EB1ng \u0111i\u1EC7n tho\u1EA1i, t\u1ED1t l\u1EAFm"
    autoProgress: 0000
  - DialogID: 2
    SentenceList:
    - "B\u1EA1n \u0111\xE3 c\xF3 \u0111\u1EE7 m\xF3n \u0111\u1ED3 c\u1EA7n thi\u1EBFt,
      tr\u01B0\u1EDBc h\u1EBFt nh\u1EDB v\xE0o E101 \u0111\u1EC3 t\xECm th\xF4ng
      tin. "
    - "\u0110\u1EB7c bi\u1EC7t l\xE0 c\xE1p d\xE2y \u0111\u1EC3 k\u1EBFt n\u1ED1i
      l\xE0 lo\u1EA1i chuy\xEAn d\u1EE5ng si\xEAu c\u1EA5p \u0111\u1EB7c bi\u1EC7c.
      N\xEAn ph\u1EA3i ch\xFA \xFD t\xECm n\xF3 \u0111\xF3"
    - "B\u1EA1n tr\u1EBB \u0111\xE3 h\u1ECDc \u0111\u1ED5i qua l\u1EA1i v\u1EDBi
      c\xE1c h\u1EC7 c\u01A1 s\u1ED1 ch\u01B0a, n\xF3 c\xF3 li\xEAn quan \u0111\xF3"
    - "C\u1ED1 l\xEAn b\u1EA1n tr\u1EBB"
    autoProgress: 00000101
  TypingSpeed: 0.02
  Voice: {fileID: 0}
  voicePitch: 1
  autoProgressDelay: 1.5
