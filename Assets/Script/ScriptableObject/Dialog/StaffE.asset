  NPCid: 5
  NPCname: "\u0440\u0443\u0441\u0441\u043A\u0438\u0439 \u043C\u0443\u0436\u0447\u0438\u043D\u0430"
  NPCAva: {fileID: -340626375, guid: 8a98d52d20f4f9049a3e00ba9c355930, type: 3}
  ListDialog:
  - DialogID: 0
    SentenceList:
    - "\u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435,
      \u043D\u043E\u0432\u044B\u0435 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B!"
    - "Ch\xE0o b\u1EA1n, t\xF4i l\xE0 ti\u1EBFn s\u0129 b\xEAn Nga, kh\xF4ng ng\u1ED1
      m\u1EDBi v\u1EC1 tr\u01B0\u1EDDng, ti\u1EBFng vi\u1EC7t c\xF2n d\u1EE1."
    autoProgress: 00000100
  - DialogID: 1
    SentenceList:
    - "Server tr\u01B0\u1EDDng n\u1ED5 r\u1ED3i!. T\xF4i t\xEDnh v\xE0o \u0111\xF3
      xem m\xE0 kh\xF4ng th\u1EA5y ch\xECa kh\xF3a \u1EDF \u0111\xE2u h\u1EBFt. C\u1EADu
      t\xECm xung quanh nha"
    - "T\u1ED1t l\u1EAFm, v\xE0o th\xF4i"
    autoProgress: 0000
  TypingSpeed: 0.02
  Voice: {fileID: 0}
  voicePitch: 1
  autoProgressDelay: 1.5
