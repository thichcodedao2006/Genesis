  NPCname: "K\u1EBB g\xE1c c\u1ED5ng (tr\xE1i tim)"
  NPCAva: {fileID: -1511162675, guid: bada855c67258bc40905d232281b74a4, type: 3}
  ListDialog:
  - DialogID: 0
    SentenceList:
    - "\u0110\u1EC3 \u0111\u1EBFn \u0111\u01B0\u1EE3c n\u01A1i kh\xF4ng ai \u0111\u1EBFn
      \u0111\u01B0\u1EE3c ph\u1EA3i s\u1EDF h\u1EEFu th\u1EE9 kh\xF4ng ai s\u1EDF
      h\u1EEFu \u0111\u01B0\u1EE3c. Ch\xECa kh\xF3a v\xE0o t\xF2a c\u0169ng ch\xEDnh
      l\xE0 ch\xECa kh\xF3a \u0111\u1EBFn tr\xE1i tim."
    autoProgress: 00
  - DialogID: 1
    SentenceList:
    - "Em \u0111\xE3 t\xECm \u0111\u01B0\u1EE3c \u0111\u01B0\u1EDDng v\xE0o c\u0169ng
      nh\u01B0 l\u1ED1i v\xE0o tim ta. Hi v\u1ECDng tri th\u1EE9c n\u01A1i \u0111\xE2y
      s\u1EBD thay \u0111\u1ED5i con ng\u01B0\u1EDDi em."
    autoProgress: 00
